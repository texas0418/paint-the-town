{
  "expo": {
    "name": "Paint the Town",
    "slug": "paint-the-town",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "painthetown",
      "w4nder"
    ],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#16344F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.paintthetown.com",
      "infoPlist": {
        "NSCalendarsUsageDescription": "Paint the Town needs calendar access to find free times for date nights and sync availability with your partner.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#16344F"
      },
      "package": "app.paintthetown.com",
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-calendar",
        {
          "calendarPermission": "Paint the Town needs calendar access to find free times for date nights and sync availability with your partner."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#27567F"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id-here"
      }
    }
  }
}
